"""\ncourse模块 - Service服务层\n"""\n\nfrom datetime import date, datetime, timedelta\nfrom typing import Optional, List, Dict, Any\n\nfrom sqlalchemy.orm import Session\n\nfrom app.api.v1.module_system.auth.service import UserService\nfrom app.core.base_crud import BaseCRUD\nfrom app.core.database import SessionDep\nfrom app.core.exceptions import CustomException\nfrom app.core.logger import logger\n\nfrom .model import *\nfrom .crud import *\nfrom .schema import *\n\n# ============================================================================
# 课程管理服务
# ============================================================================

class CourseService:
    """课程管理服务层"""

    @classmethod
    async def schedule_service(cls, auth: AuthSchema, course_data: dict) -> dict:
        """排课"""
        import logging
        logger = logging.getLogger(__name__)
        
        logger.info(f"🚀 开始排课服务，用户ID: {auth.user.id}")
        logger.debug(f"📋 课程数据: {course_data}")
        
        try:
            course = await CourseCRUD(auth).schedule_crud(course_data)
            if course and hasattr(course, 'id'):
                logger.info(f"✅ 排课服务成功，课程ID: {course.id}")
                return SimpleResponse(
                    success=True,
                    message="排课成功",
                    data={"course_id": course.id}
                ).model_dump()
            else:
                logger.error("❌ 排课服务失败，课程对象无效")
                return SimpleResponse(
                    success=False,
                    message="排课失败，课程创建异常",
                    data={}
                ).model_dump()
        except Exception as e:
            logger.error(f"❌ 排课服务异常: {e}", exc_info=True)
            return SimpleResponse(
                success=False,
                message=f"排课失败: {str(e)}",
                data={}
            ).model_dump()

    @classmethod
    async def get_upcoming_service(cls, auth: AuthSchema, days: int = 7) -> list[dict]:
        """获取近期课程"""
        from datetime import datetime, timedelta
        
        courses = await CourseCRUD(auth).get_upcoming_courses_crud(days=days)
        
        result = []
        for course in courses:
            # 组合开始时间：start_date + class_time
            if course.start_date and course.class_time:
                start_datetime = datetime.combine(course.start_date, course.class_time)
                start_time_str = start_datetime.strftime('%Y-%m-%d %H:%M:%S')
                
                # 计算结束时间：开始时间 + 课程时长
                end_datetime = start_datetime + timedelta(minutes=course.duration_minutes)
                end_time_str = end_datetime.strftime('%Y-%m-%d %H:%M:%S')
            else:
                start_time_str = None
                end_time_str = None
            
            result.append({
                "id": course.id,
                "name": course.name,
                "course_type": course.course_type.value,
                "coach": course.coach_user.username if course.coach_user else None,
                "campus": course.location,
                "court_number": course.location,  # 使用location作为court_number
                "start_time": start_time_str,
                "end_time": end_time_str,
                "max_students": course.max_students,
                "min_students": course.min_students,
                "status": course.status
            })
        
        return result\n